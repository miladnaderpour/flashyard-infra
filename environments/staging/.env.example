# =========================================================
# Flashyard staging environment template
# ---------------------------------------------------------
# This file is a TEMPLATE only.
# Do not commit real secrets.
# Copy the real values to the server runtime .env file.
#
# Intended runtime location on server:
#   /data/flashyard/staging/.env
#
# Notes:
# - RELEASE_CHANNEL must match the environment.
# - GIT_SHA and BUILD_TIME should be injected by CI/CD.
# - In Docker Compose, use the Postgres service name `db`,
#   not localhost.
# - Replace all placeholder secrets before deployment.
# =========================================================

# =========================================================
# Application identity and build metadata
# =========================================================
# Human-readable application name
APP_NAME=Flashyard API

# Environment channel: development | staging | production
RELEASE_CHANNEL=staging

# =========================================================
# Database connection
# =========================================================
# Async runtime connection used by the FastAPI app
# Host must be the Docker Compose service name: db
DATABASE_URL=postgresql+asyncpg://flashyard_user:change_me@db:5432/flashyard_staging

# Sync connection used by Alembic migrations
ALEMBIC_DATABASE_URL=postgresql+psycopg2://flashyard_user:change_me@db:5432/flashyard_staging

# =========================================================
# Authentication and security
# =========================================================
# Replace with a long random secret in the real .env
SECRET_KEY=change_this_to_a_long_random_secret

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================================================
# reCAPTCHA
# =========================================================
# Replace with real staging keys if registration protection is enabled
RECAPTCHA_SECRET=change_me
RECAPTCHA_THRESHOLD=0.5
RECAPTCHA_EXPECTED_ACTION=register

# =========================================================
# AI integration
# =========================================================
# Replace with a real key only if AI features are enabled in staging
OPENAI_API_KEY=change_me

# Default AI model and generation behavior
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.6
AI_MAX_TOKENS=2000